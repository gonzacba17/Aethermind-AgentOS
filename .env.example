# Environment Variables
# =====================
# B2B Beta — only DATABASE_URL, JWT_SECRET, and LLM keys are required.
# OAuth, Stripe, and session vars are kept for reference but not used.

# ── Required ──────────────────────────────────────

# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Database SSL (production only)
# Set to 'false' for managed DBs with self-signed certs (Railway, Render)
# DB_SSL_REJECT_UNAUTHORIZED="false"

# JWT Authentication (still required by secrets validation)
JWT_SECRET="your-secret-min-32-chars-long"

# Node Environment
NODE_ENV="production"
PORT="3001"

# API Keys for LLM providers
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_AI_API_KEY="..."

# Aethermind API (for SDK testing)
AETHERMIND_API_KEY="aether_..."
AETHERMIND_ENDPOINT="https://your-api.railway.app"

# ── Obsolete during B2B beta (kept for restore) ──

# OAuth (disabled — no public signup)
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."
# GITHUB_CLIENT_ID="..."
# GITHUB_CLIENT_SECRET="..."

# Session (disabled — no session store)
# SESSION_SECRET="your-session-secret"

# Encryption key for user API keys (disabled — clients use sdk_api_key)
# API_KEY_ENCRYPTION_KEY="..."

# Stripe (disabled — no billing)
# STRIPE_SECRET_KEY="sk_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional Services
REDIS_URL="redis://..."
SENDGRID_API_KEY="SG...."
SLACK_WEBHOOK_URL="https://hooks.slack.com/..."
