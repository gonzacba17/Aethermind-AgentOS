# Environment Variables

# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Database SSL (production only)
# Set to 'false' for managed DBs with self-signed certs (Railway, Render)
# DB_SSL_REJECT_UNAUTHORIZED="false"

# API Keys for LLM providers
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GOOGLE_AI_API_KEY="..."

# JWT Authentication
JWT_SECRET="your-secret-min-32-chars-long"

# Node Environment
NODE_ENV="production"
PORT="3001"

# OAuth (optional)
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."
GITHUB_CLIENT_ID="..."
GITHUB_CLIENT_SECRET="..."

# Session
SESSION_SECRET="your-session-secret"

# Encryption key for user API keys (AES-256)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# API_KEY_ENCRYPTION_KEY="..."

# Aethermind API (for SDK testing)
AETHERMIND_API_KEY="aether_..."
AETHERMIND_ENDPOINT="https://your-api.railway.app"

# Optional Services
REDIS_URL="redis://..."
SENDGRID_API_KEY="SG...."
SLACK_WEBHOOK_URL="https://hooks.slack.com/..."