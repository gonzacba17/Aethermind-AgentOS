{
  "name": "@aethermind/agent",
  "version": "0.1.4",
  "description": "Lightweight SDK for monitoring AI API costs with Aethermind",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/esm/index.d.ts"
    }
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm clean && pnpm build:esm && pnpm build:cjs && pnpm build:markers",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build:markers": "node --input-type=commonjs -e \"const fs=require('fs');fs.writeFileSync('dist/cjs/package.json','{\\\"type\\\":\\\"commonjs\\\"}');fs.writeFileSync('dist/esm/package.json','{\\\"type\\\":\\\"module\\\"}')\"",
    "dev": "tsc --watch --project tsconfig.esm.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit --project tsconfig.esm.json",
    "prepublishOnly": "pnpm build && pnpm typecheck",
    "test": "vitest"
  },
  "keywords": [
    "openai",
    "anthropic",
    "ai",
    "monitoring",
    "cost-tracking",
    "telemetry",
    "llm",
    "observability",
    "finops",
    "ollama"
  ],
  "author": "Aethermind Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gonzacba17/Aethermind-AgentOS.git",
    "directory": "packages/agent"
  },
  "bugs": {
    "url": "https://github.com/gonzacba17/Aethermind-AgentOS/issues"
  },
  "homepage": "https://aethermind.io",
  "peerDependencies": {
    "openai": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.8",
    "rimraf": "^5.0.10"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
