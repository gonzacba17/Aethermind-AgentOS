# Dashboard Environment Variables - Local Development

# API Configuration (REQUIRED)
# Local development: http://localhost:3001
# Production (Railway): https://aethermind-agentos-production.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket URL (auto-constructed from API_URL, but can be overridden)
# Local: ws://localhost:3001
# Production: wss://aethermind-agentos-production.up.railway.app
NEXT_PUBLIC_WS_URL=

# Landing Page URL (for redirects)
# Local: http://localhost:3000
# Production: https://aethermind-page.vercel.app
NEXT_PUBLIC_LANDING_URL=http://localhost:3000

# Environment
NODE_ENV=development
